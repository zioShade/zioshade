#version 450
// Regression guard: compute built-ins must be threaded as entry-point
// system-value inputs on every backend (MSL [[thread_position_*]], HLSL
// SV_DispatchThreadID/SV_GroupThreadID/SV_GroupID/SV_GroupIndex, WGSL
// @builtin(...)). Otherwise they leak as undeclared identifiers (silent-wrong).
layout(local_size_x = 8) in;
layout(set = 0, binding = 0, std430) buffer Buf { uint data[]; } b;
void main() {
    b.data[gl_GlobalInvocationID.x] =
        gl_LocalInvocationID.x + gl_WorkGroupID.x + gl_LocalInvocationIndex;
}
