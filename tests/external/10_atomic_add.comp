// Compute shader: atomicAdd on an SSBO counter.
// Expected: all 4 backends emit successfully.
#version 450

layout(local_size_x = 64) in;

layout(set = 0, binding = 0, std430) buffer Counter {
    uint counter;
} b;

void main() {
    atomicAdd(b.counter, 1u);
}
