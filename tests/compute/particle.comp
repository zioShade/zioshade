#version 450
layout(local_size_x = 256) in;
struct Particle {
    vec2 pos;
    vec2 vel;
    float life;
};
layout(std430, binding = 0) buffer Particles {
    Particle particles[];
};
void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= particles.length()) return;
    Particle p = particles[idx];
    p.pos += p.vel * 0.016;
    p.life -= 0.016;
    if (p.life <= 0.0) {
        p.pos = vec2(0.0);
        p.vel = vec2(0.0);
        p.life = 1.0;
    }
    particles[idx] = p;
}
