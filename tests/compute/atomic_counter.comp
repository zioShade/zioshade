#version 450
layout(local_size_x = 64) in;
layout(std430, binding = 0) buffer Counter {
    uint count;
    float results[];
};
void main() {
    uint idx = gl_GlobalInvocationID.x;
    float val = float(idx) * float(idx);
    uint slot = atomicAdd(count, 1u);
    if (slot < results.length()) {
        results[slot] = val;
    }
}
