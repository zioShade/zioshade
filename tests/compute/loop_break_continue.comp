#version 450
layout(local_size_x = 64) in;
layout(std430, binding = 0) buffer Data {
    float values[];
};
void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= values.length()) return;
    float sum = 0.0;
    for (int i = 0; i < 8; i++) {
        if (i % 2 == 0) continue;
        if (sum > 10.0) break;
        sum += float(i) * values[idx];
    }
    values[idx] = sum;
}
