// Tests: compute shader with nested loops and atomic operations
#version 450
layout(local_size_x = 32) in;

layout(std430, binding = 0) buffer Result {
    int counts[];
};

void main() {
    uint gid = gl_GlobalInvocationID.x;
    
    int sum = 0;
    for (int i = 0; i < 8; i++) {
        int val = int(gid) * 10 + i;
        if (val % 3 == 0) {
            sum += val;
        } else {
            sum -= val % 7;
        }
    }
    
    counts[gid] = sum;
}
