// Test: compute with multiple SSBOs
#version 450

layout(local_size_x = 128) in;

layout(binding = 0) readonly buffer InputA {
    float data[];
} inputA;

layout(binding = 1) readonly buffer InputB {
    float data[];
} inputB;

layout(binding = 2) writeonly buffer Output {
    float data[];
} outputBuf;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    
    float a = inputA.data[idx];
    float b = inputB.data[idx];
    
    float sum = a + b;
    float prod = a * b;
    float maxab = max(a, b);
    float result = sum * 0.5 + prod * 0.3 + maxab * 0.2;
    
    outputBuf.data[idx] = result;
}
