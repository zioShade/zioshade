#version 450
layout(local_size_x = 64) in;
layout(std430, binding = 0) buffer Data {
    float values[];
} data;

shared float scratch[64];

void main() {
    uint idx = gl_LocalInvocationID.x;
    scratch[idx] = float(idx);
    barrier();
    data.values[gl_GlobalInvocationID.x] = scratch[63 - idx];
}
