// Tests: compute shader with shared memory
#version 450
layout(local_size_x = 64) in;
uniform int u_count;

shared float s_data[64];

void main() {
    uint idx = gl_LocalInvocationID.x;
    s_data[idx] = float(idx) * 0.1;
    barrier();
    
    float sum = 0.0;
    for (uint i = 0u; i < 64u; i++) {
        sum += s_data[i];
    }
    
    if (idx == 0u) {
        // Use the sum somehow
        float result = sum / 64.0;
    }
}
