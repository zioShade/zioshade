// Tests: compute shader with workgroup barrier and shared memory
#version 450
layout(local_size_x = 32) invoc;
shared float s_data[32];

void main() {
    uint tid = gl_LocalInvocationID.x;
    s_data[tid] = float(tid) * 0.1;
    barrier();
    float sum = 0.0;
    for (uint i = 0; i < 32; i++) {
        sum += s_data[i];
    }
    // sum = 0.1 * (0 + 1 + ... + 31) = 0.1 * 496 = 49.6
}
