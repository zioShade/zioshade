// Tests: compute shader writing to SSBO with index calculation
#version 450
layout(local_size_x = 64) in;
layout(std430, binding = 0) buffer Data {
    float values[];
} buf;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    uint total = gl_NumWorkGroups.x * 64u;
    float t = float(idx) / float(total);
    buf.values[idx * 2] = sin(t * 6.28);
    buf.values[idx * 2 + 1] = cos(t * 6.28);
}
